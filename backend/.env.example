# ─── Server ────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ───────────────────────────────────────
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/snackzone?retryWrites=true&w=majority

# ─── JWT ───────────────────────────────────────────
JWT_SECRET=change_this_to_a_very_long_random_string_of_at_least_32_characters

# ─── Redis (OPTIONAL but recommended) ──────────────
# Local:  redis://localhost:6379
# Remote: redis://:yourpassword@host:port
# Leave blank to skip Redis (falls back to MongoDB)
REDIS_URL=redis://localhost:6379

# ─── SMS / OTP Provider (pick ONE) ─────────────────
# ── Option 1: Fast2SMS (recommended for India) ──────
# Sign up at fast2sms.com → Dev API → copy key
# NOTE: Use route=otp, does NOT require DLT registration
FAST2SMS_API_KEY=

# ── Option 2: Twilio ────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── Option 3: MSG91 ─────────────────────────────────
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=

# If NONE are set → DEV mode prints OTP to server console
# and returns devOtp / devDeliveryOTP in API response
